// Added for adding captive inidividuals

// Defining a function called addCaptiveJuveniles - targetPop (the pop individuals are being added into), sourcePop the population being used as parents to create the juveniles (West pop), nReleases ( how many juveniles to add this year) 

function (void) addCaptiveJuveniles(o<Subpopulation>$ targetPop,
	o<Subpopulation>$ sourcePop,
	i$ nReleases)
{
	
	// If the releases are 0 then don't do anything 
	if (nReleases <= 0)
		return;
	
	// Cannot have less than 2 individuals in source pop - if there are then captive release is skipped and a warning is printed 
	if (sourcePop.individualCount < 2) {
		print("WARN: captive releases skipped (sourcePop too small): pop " + sourcePop.id);
		return;
	}
	
	// Prefer adults as parents is there are any, else fall back to anyone being parents 
	
	// Creates a list of candidate parents form sourcePop - indv with age bestweesn rep1st and repLast - prefer adults
	parentsPool = sourcePop.individuals[sourcePop.individuals.age >= rep1st & sourcePop.individuals.age <= repLast];
	// If there aren't at least 2 breeding-age individuals then use any individual in the source pop 
	if (parentsPool.size() < 2)
		parentsPool = sourcePop.individuals;
	// Check if still less than 2 candidates - print warning and exit 
	if (parentsPool.size() < 2) {
		print("WARN: captive releases skipped (not enough parents in pool): pop " + sourcePop.id);
		return;
	}
	
	// Loop nReleases times - once per juvenile to be released - randomly choose two distincr parents from parentspool - create offspring by crossing parents, replace =F so the same indv cannot be picked twice 
	
	for (i in seqLen(nReleases))
	{
		fem = parentsPool[parentsPool.sex == "F"];
		mal = parentsPool[parentsPool.sex == "M"];
		if (fem.size() < 1 | mal.size() < 1) {
			print("WARN: captive releases skipped (need both sexes): pop " + sourcePop.id);
			return;
		}
		prF = sample(fem, 1);
		prM = sample(mal, 1);
		pup = targetPop.addCrossed(prF, prM);
		pup.age  = 0;
		pup.tag  = 0;
		pup.tagF = 1.0;
		initRecruitTrack(pup);
	}
}

//Functions

function (s)getNeutHet (o pop, o mut) {
	
	total = 0.0;
	
	for (ind in pop.individuals)
	{
		// Calculate the nucleotide heterozygosity of this individual
		muts0 = ind.haplosomes[0].mutationsOfType(mut);
		muts1 = ind.haplosomes[1].mutationsOfType(mut);
		
		// Count the shared mutations
		shared_count = sum(match(muts0, muts1) >= 0);
		
		// All remaining mutations in the genomes are unshared (i.e. heterozygous)
		unshared_count = muts0.size() + muts1.size() - 2 * shared_count;
		
		// pi is the mean heterozygosity across the chromosome
		pi_ind = unshared_count / (sim.chromosome.lastPosition + 1);
		total = total + pi_ind;
	}
	
	size = pop.individuals.size();
	pi = total / size;
	
	
	//	mut=sim.mutations;
	mut=sim.mutationsOfType(mut);
	freqs=sim.mutationFrequencies(pop,mut);
	mut=mut[freqs>0&freqs<1];
	DEN=sum(1/seqAlong(mut)[1:(length(mut)-1)]);
	theta=length(mut)/DEN;
	pi_theta=theta/sim.chromosome.lastPosition;
	
	out = sim.cycle + "\t" + pop.getValue("targetN") + "\t" + pop.tag + "\t" + pop.id + "\t" + pi + "\t" +size+ "\t" +theta+ "\t" +pi_theta;
	return out;
}

function (s)getTotalHet (o pop) {
	
	total = 0.0;
	
	for (ind in pop.individuals)
	{
		// Calculate the nucleotide heterozygosity of this individual
		muts0 = ind.haplosomes[0].mutations;
		muts1 = ind.haplosomes[1].mutations;
		
		// Count the shared mutations
		shared_count = sum(match(muts0, muts1) >= 0);
		
		// All remaining mutations in the genomes are unshared (i.e. heterozygous)
		unshared_count = muts0.size() + muts1.size() - 2 * shared_count;
		
		// pi is the mean heterozygosity across the chromosome
		pi_ind = unshared_count / (sim.chromosome.lastPosition + 1);
		total = total + pi_ind;
	}
	
	size = pop.individuals.size();
	pi = total / size;
	
	mut=sim.mutations;
	//	mut=sim.mutationsOfType(m1);
	freqs=sim.mutationFrequencies(pop,mut);
	mut=mut[freqs>0&freqs<1];
	DEN=sum(1/seqAlong(mut)[1:(length(mut)-1)]);
	theta=length(mut)/DEN;
	pi_theta=theta/sim.chromosome.lastPosition;
	
	out = sim.cycle + "\t" + pop.getValue("targetN") + "\t" + pop.tag + "\t" + pop.id + "\t" + pi + "\t" +size+ "\t" +theta+ "\t" +pi_theta;
	return out;
}



function (s) getMutSum(o pop, i mGenotype)
{
	// neutral type may not exist in some runTypes
	mNeutral = NULL;
	if (exists("mut_neutral"))
		mNeutral = sim.mutationTypes[sim.mutationTypes.id == mut_neutral];
	all_muts = sim.mutations;
	freqMut  = sim.mutationFrequencies(pop, all_muts);
	
	ID       = all_muts.id;
	TYPE     = all_muts.mutationType.id;
	POS      = all_muts.position;
	orgGen   = all_muts.originTick;
	orgPop   = all_muts.subpopID;
	ScoefMut = abs(all_muts.selectionCoeff);
	DcoefMut = all_muts.mutationType.dominanceCoeff;
	
	nM = size(all_muts);
	
	if (mGenotype > 0)
	{
		inds = pop.individuals;
		nI   = size(inds);
		
		// initialize counts
		HomRef = rep(0.0, nM);
		HomAlt = rep(0.0, nM);
		Het    = rep(0.0, nM);
		
		// precompute mapping from mutations to indices in all_muts
		// so we can index quickly
		mutIndex = integer(nM);
		for (iMut in seqLen(nM))
			mutIndex[iMut] = iMut;  // identity mapping if all_muts has no duplicates
		
		// Loop over individuals (outer), mutations inside via uniqueMutations
		for (ind in inds)
		{
			G1 = ind.haplosomes[0];
			G2 = ind.haplosomes[1];
			
			// mutations present in this individual
			m_ind = ind.uniqueMutations;
			
			if (!size(m_ind))
			{
				// no mutations at all => all sites HomRef for this individual
				// we’ll account for them by adding 1 to HomRef for all mutations
				// at the end; for now just skip
				next;
			}
			
			// Map these mutations to their indices in all_muts
			idx = match(m_ind, all_muts);
			// idx could contain -1 if all_muts and uniqueMutations differ, but
			// in your setup they should be consistent.
			
			// presence on each genome
			has1 = G1.containsMutations(m_ind);
			has2 = G2.containsMutations(m_ind);
			
			// homozygous ALT
			isHomAlt = has1 & has2;
			if (sum(isHomAlt))
				HomAlt[idx[isHomAlt]] = HomAlt[idx[isHomAlt]] + 1;
			
			// heterozygotes
			isHet = (has1 & !has2) | (!has1 & has2);
			if (sum(isHet))
				Het[idx[isHet]] = Het[idx[isHet]] + 1;
			
			// HomRef we get later as: N - HomAlt - Het
		}
		
		// individuals with no mutations at all are HomRef for all sites
		// but since they were skipped entirely, that’s fine:
		HomRef = nI - HomAlt - Het;
		
		// convert counts to proportions
		HomRef = HomRef / nI;
		HomAlt = HomAlt / nI;
		Het    = Het    / nI;
	}
	else
	{
		HomRef = "NA";
		HomAlt = "NA";
		Het    = "NA";
	}
	
	out = sim.cycle + "\t" +
		pop.getValue("targetN") + "\t" +
		pop.tag + "\t" + pop.id + "\t" +
		pop.tag + "\t" + pop.individualCount + "\t" +
		TYPE + "\t" + ID + "\t" + POS + "\t" +
		orgGen + "\t" + orgPop + "\t" +
		ScoefMut + "\t" + DcoefMut + "\t" +
		freqMut + "\t" +
		HomRef + "\t" + HomAlt + "\t" + Het;
	
	return out;
}

function (s) fixedMutations(o pop)
{
	mNeutral=sim.mutationTypes[sim.mutationTypes.id==mut_neutral];
	all_muts=sim.mutations;
	non_neutral=all_muts[all_muts.mutationType!=mNeutral];
	fixed=non_neutral[sim.mutationFrequencies(pop,non_neutral)==1.0];
	if(length(fixed)>0)
	{
		ID=fixed.id;
		TYPE=fixed.mutationType.id;
		POS=fixed.position;
		orgGen=fixed.originTick;
		orgPop=fixed.subpopID;
		ScoefMut=abs(fixed.selectionCoeff);
		DcoefMut=fixed.mutationType.dominanceCoeff;
		out=sim.cycle + "\t" + pop.getValue("targetN") + "\t" + pop.tag +"\t"+ pop.id +"\t"+ pop.tag +"\t"+ pop.individualCount +"\t"+ TYPE +"\t"+ ID +"\t"+ POS +"\t"+ orgGen +"\t"+ orgPop +"\t"+ ScoefMut +"\t"+ DcoefMut;
	} else {out=sim.cycle + "\t" + pop.getValue("targetN") + "\t" + pop.tag +"\t"+ pop.id +"\t"+ pop.tag +"\t"+ pop.individualCount + "\t" + "NA" + "\t" + "NA" + "\t" + "NA" + "\t" + "NA" + "\t" + "NA" + "\t" + "NA" + "\t" + "NA";}
	return(out);
}


function (s) getIndvSummary(o pop, o individuals)
{
	mNeutral=sim.mutationTypes[sim.mutationTypes.id==mut_neutral];
	out=c();
	for(indv in individuals){
		mut_all=indv.uniqueMutations;
		mut=mut_all[mut_all.mutationType!=mNeutral];
		if(length(mut)==0){next;}
		index=indv.pedigreeID;
		age=indv.age;
		mutOrgGen=mut.originGeneration;
		mutOrgPop=mut.subpopID;
		mutS=mut.selectionCoeff;
		mutH=mut.mutationType.dominanceCoeff;
		mutFreq=sim.mutationFrequencies(pop,mut);
		HomRef=sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==F&indv.haplosomes[1].containsMutations(applyValue)==F)/indv.size();");
		HomAlt=sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==T&indv.haplosomes[1].containsMutations(applyValue)==T)/indv.size();");
		Het=sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==T&indv.haplosomes[1].containsMutations(applyValue)==F)/indv.size();")+sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==F&indv.haplosomes[1].containsMutations(applyValue)==T)/indv.size();");
		
		Lmut=length(mut);
		f11=sum(HomAlt)/Lmut;
		sHom=mean(abs(mutS[HomAlt==1]));
		if(isNULL(sHom)){sHom=0;}
		f01=sum(Het)/Lmut;
		shHet=mean(abs(mutS[Het==1])*mutH[Het==1]);
		if(isNULL(shHet)){shHet=0;}
		sHet=mean(abs(mutS[Het==1]));
		if(isNULL(sHet)){sHet=0;}
		
		relzLoad_f2=Lmut*(f11*sHom+f01*shHet);
		mskLoad_f2=Lmut*f01*((0.5*sHet)-shHet);
		totalLoad_f2=Lmut*(f11*sHom+(0.5*f01)*sHet);
		
		// Calculate the neutral nucleotide heterozygosity of this individual
		muts0 = indv.haplosomes[0].mutationsOfType(mNeutral);
		muts1 = indv.haplosomes[1].mutationsOfType(mNeutral);
		
		// Count the shared mutations
		shared_count = sum(match(muts0, muts1) >= 0);
		
		// All remaining mutations in the genomes are unshared (i.e. heterozygous)
		unshared_count = muts0.size() + muts1.size() - 2 * shared_count;
		
		// pi is the mean heterozygosity across the chromosome
		pi_ind = unshared_count / (sim.chromosome.lastPosition + 1);
		
		indv_out=sim.cycle + "\t" + pop.getValue("targetN") + "\t" + pop.tag +"\t"+ pop.id +"\t" + index +"\t"+ age +"\t"+indv.pedigreeID+"\t"+paste(indv.pedigreeParentIDs,sep="_")+"\t"+paste(indv.pedigreeGrandparentIDs,sep="_") +"\t"+ relzLoad_f2 +"\t"+ mskLoad_f2 +"\t"+ totalLoad_f2 +"\t"+ pop.cachedFitness(indv.index) +"\t"+ pi_ind;
		
		out=c(out,indv_out);
	}
	return(out);
}


// Heterozygosity count window
function (i$)HeteroCountWindow(o<Haplosome>$ genome1, o<Haplosome>$ genome2 ,integer$ window1 , integer$ window2) ///Calc hetero between 2 genomes only for a certain window
{
	muts1 = genome1.mutations;
	muts1 = muts1[muts1.position>=window1 & muts1.position<=window2];
	
	muts2 = genome2.mutations;
	muts2 = muts2[muts2.position>=window1 & muts2.position<=window2];
	

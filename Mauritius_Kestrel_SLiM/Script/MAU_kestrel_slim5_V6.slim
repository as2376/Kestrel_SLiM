function (s) getIndvLoadTarget(o target_indv)
{
	mNeutral=sim.mutationTypes[sim.mutationTypes.id==mut_neutral];
	pop_indv=target_indv;
	out=c();
	pop=unique(target_indv.subpopulation);
	for(indv in pop_indv){
		mut=indv.uniqueMutations;
		mut=mut[mut.mutationType!=mNeutral];
		if(length(mut)==0){next;}
		index=indv.pedigreeID;
		age=indv.age;
		mutOrgGen=mut.originTick;
		mutOrgPop=mut.subpopID;
		mutS=mut.selectionCoeff;
		mutH=mut.mutationType.dominanceCoeff;
		mutFreq=sim.mutationFrequencies(pop,mut);
		HomRef=sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==F&indv.haplosomes[1].containsMutations(applyValue)==F)/indv.size();");
		HomAlt=sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==T&indv.haplosomes[1].containsMutations(applyValue)==T)/indv.size();");
		Het=sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==T&indv.haplosomes[1].containsMutations(applyValue)==F)/indv.size();")+sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==F&indv.haplosomes[1].containsMutations(applyValue)==T)/indv.size();");
		
		Lmut=length(mut);
		f11=sum(HomAlt)/Lmut;
		sHom=mean(abs(mutS[HomAlt==1]));
		if(isNULL(sHom)){sHom=0;}
		f01=sum(Het)/Lmut;
		shHet=mean(abs(mutS[Het==1])*mutH[Het==1]);
		if(isNULL(shHet)){shHet=0;}
		sHet=mean(abs(mutS[Het==1]));
		if(isNULL(sHet)){sHet=0;}
		
		relzLoad_f2=Lmut*(f11*sHom+f01*shHet);
		mskLoad_f2=Lmut*f01*((0.5*sHet)-shHet);
		totalLoad_f2=Lmut*(f11*sHom+(0.5*f01)*sHet);
		
		indv_out=sim.cycle +"\t"+ pop.id +"\t"+ index +"\t"+ age +"\t"+ relzLoad_f2 +"\t"+ mskLoad_f2 +"\t"+ totalLoad_f2 +"\t"+ pop.cachedFitness(indv.index);
		
		out=c(out,indv_out);
	}
	return(out);
}

function (s) getROH(o pop, o individuals, i ROHcutoff, i winS, i winE)
{
	pop_indv=individuals;
	out=c();
	chromL=winE;
	ind_ROH=c();
	for(indv in pop_indv){
		if(community.modelType=="WF"){age="NA";}else{age=indv.age;}
		// ROH
		indm = sortBy(indv.haplosomes.mutations, "position");
		indm = indm[indm.position>=winS & indm.position<=winE];
		indm_uniq = unique(indm);
		genotype = sapply(indm_uniq, "sum(indm == applyValue);");
		if (isNULL(genotype)) {
			ind_ROH = c(ind_ROH, "NA");
			next;
		}
		ID_het = (genotype == 1); //outputs T/F for genotypes if they are het or homDer
		ID_homDer = (genotype == 2);
		pos_het = indm_uniq.position[ID_het]; //outputs positions of heterozgoys genotypes
		startpos = c(winS, pos_het); //adds 0 to beggining of vector of hets
		endpos = c(pos_het, winE); //adds last position in genome to vector of hets
		pos_het_diff = endpos - startpos;
		ROH_startpos = startpos[pos_het_diff > ROHcutoff]; //filter out startpos that dont correspond to ROH > ROH_length
		ROH_endpos = endpos[pos_het_diff > ROHcutoff];
		ROH_length = pos_het_diff[pos_het_diff > ROHcutoff]; //vector of ROHs for each individual
		SROH = sum(ROH_length);
		NROH = length(ROH_length);
		FROH=SROH/winE;
		if(NROH>0){
			ROH_coords=sapply(0:(length(ROH_startpos)-1),"paste(ROH_startpos[applyValue],ROH_endpos[applyValue],sep='-');");
		} else {ROH_coords=0;}
		indv_out=sim.cycle +"\t"+ pop.id +"\t"+ indv.pedigreeID +"\t"+ age +"\t"+ SROH +"\t"+ NROH +"\t"+ FROH +"\t"+ paste(ROH_length,sep=",") +"\t"+ paste(ROH_coords,sep=",") +"\t"+ ROHcutoff +"\t"+ winS +"\t"+ winE;
		out=c(out,indv_out);
	}
	if(sum(isNULL(out)>0)){out="NA";}
	return(out);
}

function (s) getROH_Fitness(o pop, o individuals, i ROHcutoff, i winS, i winE)
{
	out = c();
	for (indv in individuals)
	{
		age = (community.modelType=="WF") ? "NA" else indv.age;
		
		// Added: sex (requires initializeSex("A") in initialize())
		sex = indv.sex;
		
		// cached genetic fitness from SLiM
		fit = pop.cachedFitness(indv.index);
		
		// recruitment tracking fields
		initRecruitTrack(indv);
		recruited  = indv.getValue("recruited");
		recruitGen = indv.getValue("recruitGen");
		nBreed     = indv.getValue("nBreed");
		nOff       = indv.getValue("nOff");
		
		// Added: a recruitment-like outcome 
		// (1 if individual produced >=1 offspring ever)
		hadOffspring = asInteger(nOff > 0);
		
		// Gather mutations in the window and compute ROH exactly as in getROH()
		indm = sortBy(indv.haplosomes.mutations, "position");
		indm = indm[indm.position >= winS & indm.position <= winE];
		
		// If no mutations in window, match getROH() & output NA (no ROH inference possible)
		if (size(indm) == 0)
		{
			SROH = "NA";
			NROH = "NA";
			FROH = "NA";
			ROH_length = "NA";
			ROH_coords = "NA";
			
			indv_out = sim.cycle + "\t" + pop.id + "\t" + indv.pedigreeID + "\t" + sex + "\t" + age + "\t" +
				SROH + "\t" + NROH + "\t" + FROH + "\t" + fit + "\t" +
				recruited + "\t" + hadOffspring + "\t" + recruitGen + "\t" + nBreed + "\t" + nOff + "\t" +
				ROH_length + "\t" + ROH_coords + "\t" + ROHcutoff + "\t" + winS + "\t" + winE;
			
			out = c(out, indv_out);
			next;
		}
		
		indm_uniq = unique(indm);
		genotype = sapply(indm_uniq, "sum(indm == applyValue);");
		
		// If something weird happens, still output a line (don’t silently drop)
		if (isNULL(genotype))
		{
			SROH = 0;
			NROH = 0;
			FROH = 0.0;
			ROH_length = 0;
			ROH_coords = 0;
			
			indv_out = sim.cycle + "\t" + pop.id + "\t" + indv.pedigreeID + "\t" + sex + "\t" + age + "\t" +
				SROH + "\t" + NROH + "\t" + FROH + "\t" + fit + "\t" +
				recruited + "\t" + hadOffspring + "\t" + recruitGen + "\t" + nBreed + "\t" + nOff + "\t" +
				ROH_length + "\t" + ROH_coords + "\t" + ROHcutoff + "\t" + winS + "\t" + winE;
			
			out = c(out, indv_out);
			next;
		}
		
		ID_het = (genotype == 1);
		pos_het = indm_uniq.position[ID_het];
		
		startpos = c(winS, pos_het);
		endpos   = c(pos_het, winE);
		
		pos_het_diff = endpos - startpos;
		
		ROH_startpos = startpos[pos_het_diff > ROHcutoff];
		ROH_endpos   = endpos[pos_het_diff > ROHcutoff];
		ROH_length   = pos_het_diff[pos_het_diff > ROHcutoff];
		
		SROH = sum(ROH_length);
		NROH = length(ROH_length);
		FROH = SROH / winE;
		
		if (NROH > 0)
			ROH_coords = sapply(0:(length(ROH_startpos)-1),
			"paste(ROH_startpos[applyValue], ROH_endpos[applyValue], sep='-');");
		else
			ROH_coords = 0;
		
		indv_out = sim.cycle + "\t" + pop.id + "\t" + indv.pedigreeID + "\t" + sex + "\t" + age + "\t" +
			SROH + "\t" + NROH + "\t" + FROH + "\t" + fit + "\t" +
			recruited + "\t" + hadOffspring + "\t" + recruitGen + "\t" + nBreed + "\t" + nOff + "\t" +
			paste(ROH_length, sep=",") + "\t" + paste(ROH_coords, sep=",") + "\t" +
			ROHcutoff + "\t" + winS + "\t" + winE;
		
		out = c(out, indv_out);
	}
	
	if (sum(isNULL(out) > 0))
		out = "NA";
	return(out);
}

// Added for comparison with genomic output - big output file with lots of key parameters

function (s) getIndvGenomeMetrics(o pop, o individuals, i ROHcutoff, i winS, i winE, i chrEnd)
{
	out = c();
	mNeutral = sim.mutationTypes[sim.mutationTypes.id == mut_neutral];
	
	for (indv in individuals)
	{
		age = indv.age;
		sex = indv.sex;
		fit = pop.cachedFitness(indv.index);
		
		// recruitment and breeding tracking fields already used elsewhere
		initRecruitTrack(indv);
		recruited  = indv.getValue("recruited");
		recruitGen = indv.getValue("recruitGen");
		nBreed     = indv.getValue("nBreed");
		nOff       = indv.getValue("nOff");
		hadOffspring = asInteger(nOff > 0);
		
		
		// individual heterozygosity
		// use the same chromosome-only logic as getIndvMetrics()
		
		muts0 = indv.haplosomes[0].mutations;
		muts1 = indv.haplosomes[1].mutations;
		
		muts0 = muts0[muts0.position < chrEnd];
		muts1 = muts1[muts1.position < chrEnd];
		
		shared_count = sum(match(muts0, muts1) >= 0);
		unshared_count = muts0.size() + muts1.size() - 2 * shared_count;
		Het_indv = unshared_count / chrEnd;
		
		
		// ROH / FROH using the chosen cutoff
		// keeping raw ROH lengths & coords so I  can later derive >1 Mb if wanted - to match genomic data exactly - currently 500 kb 
		
		indm = sortBy(indv.haplosomes.mutations, "position");
		indm = indm[indm.position >= winS & indm.position <= winE];
		
		if (size(indm) == 0)
		{
			SROH = 0;
			NROH = 0;
			FROH = 0.0;
			ROH_length = 0;
			ROH_coords = 0;
		}
		else
		{
			indm_uniq = unique(indm);
			genotype = sapply(indm_uniq, "sum(indm == applyValue);");
			
			if (isNULL(genotype))
			{
				SROH = 0;
				NROH = 0;
				FROH = 0.0;
				ROH_length = 0;
				ROH_coords = 0;
			}
			else
			{
				ID_het = (genotype == 1);
				pos_het = indm_uniq.position[ID_het];
				
				startpos = c(winS, pos_het);
				endpos   = c(pos_het, winE);
				pos_het_diff = endpos - startpos;
				
				ROH_startpos = startpos[pos_het_diff > ROHcutoff];
				ROH_endpos   = endpos[pos_het_diff > ROHcutoff];
				ROH_length   = pos_het_diff[pos_het_diff > ROHcutoff];
				
				SROH = sum(ROH_length);
				NROH = length(ROH_length);
				FROH = SROH / winE;
				
				if (NROH > 0)
					ROH_coords = sapply(0:(length(ROH_startpos)-1),
					"paste(ROH_startpos[applyValue], ROH_endpos[applyValue], sep='-');");
				else
					ROH_coords = 0;
			}
		}
		
		
		// direct individual deleterious site/allele counts
		// all deleterious = all non-neutral mutations
		// moderate = 1e-3 <= |s| < 1e-2
		// strong   = |s| >= 1e-2
		
		mut = indv.uniqueMutations;
		mut = mut[mut.mutationType != mNeutral];
		
		nHetDelSites_all = 0;
		nHomDelSites_all = 0;
		nTotalDelAlleles_all = 0;
		
		nHetDelSites_mod = 0;
		nHomDelSites_mod = 0;
		nTotalDelAlleles_mod = 0;
		
		nHetDelSites_strong = 0;
		nHomDelSites_strong = 0;
		nTotalDelAlleles_strong = 0;
		
		if (length(mut) > 0)
		{
			has0 = indv.haplosomes[0].containsMutations(mut);
			has1 = indv.haplosomes[1].containsMutations(mut);
			
			isHet = (has0 & !has1) | (!has0 & has1);
			isHom = (has0 & has1);
			
			absS = abs(mut.selectionCoeff);
			
			// all deleterious
			nHetDelSites_all = sum(isHet);
			nHomDelSites_all = sum(isHom);
			nTotalDelAlleles_all = nHetDelSites_all + 2 * nHomDelSites_all;
			
			// moderately deleterious
			isMod = (absS >= 1e-3 & absS < 1e-2);
			nHetDelSites_mod = sum(isHet & isMod);
			nHomDelSites_mod = sum(isHom & isMod);
			nTotalDelAlleles_mod = nHetDelSites_mod + 2 * nHomDelSites_mod;
			
			// strongly deleterious
			isStrong = (absS >= 1e-2);
			nHetDelSites_strong = sum(isHet & isStrong);
			nHomDelSites_strong = sum(isHom & isStrong);
			nTotalDelAlleles_strong = nHetDelSites_strong + 2 * nHomDelSites_strong;
		}
		
		yr = asInteger(minYear + (sim.cycle - g_T_demo));
		
		indv_out = sim.cycle + "\t" + yr + "\t" + pop.id + "\t" + indv.pedigreeID + "\t" +
			sex + "\t" + age + "\t" + Het_indv + "\t" +
			SROH + "\t" + NROH + "\t" + FROH + "\t" +
			paste(ROH_length, sep=",") + "\t" + paste(ROH_coords, sep=",") + "\t" +
			fit + "\t" + recruited + "\t" + hadOffspring + "\t" + recruitGen + "\t" + nBreed + "\t" + nOff + "\t" +
			nHetDelSites_all + "\t" + nHomDelSites_all + "\t" + nTotalDelAlleles_all + "\t" +
			nHetDelSites_mod + "\t" + nHomDelSites_mod + "\t" + nTotalDelAlleles_mod + "\t" +
			nHetDelSites_strong + "\t" + nHomDelSites_strong + "\t" + nTotalDelAlleles_strong;
		
		out = c(out, indv_out);
	}
	return(out);
}

function (s) getIndvMetrics(o target_indv, i chrEnd)
{
	mNeutral=sim.mutationTypes[sim.mutationTypes.id==mut_neutral];
	pop_indv=target_indv;
	out=c();
	pop=unique(target_indv.subpopulation);
	for(indv in pop_indv){
		mut=indv.uniqueMutations;
		mut=mut[mut.mutationType!=mNeutral];
		if(length(mut)==0){next;}
		index=indv.pedigreeID;
		age=indv.age;
		mutOrgGen=mut.originTick;
		mutOrgPop=mut.subpopID;
		mutS=mut.selectionCoeff;
		mutH=mut.mutationType.dominanceCoeff;
		mutFreq=sim.mutationFrequencies(pop,mut);
		HomRef=sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==F&indv.haplosomes[1].containsMutations(applyValue)==F)/indv.size();");
		HomAlt=sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==T&indv.haplosomes[1].containsMutations(applyValue)==T)/indv.size();");
		Het=sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==T&indv.haplosomes[1].containsMutations(applyValue)==F)/indv.size();")+sapply(mut, "sum(indv.haplosomes[0].containsMutations(applyValue)==F&indv.haplosomes[1].containsMutations(applyValue)==T)/indv.size();");
		Lmut=length(mut);
		f11=sum(HomAlt)/Lmut;
		sHom=mean(abs(mutS[HomAlt==1]));
		if(isNULL(sHom)){sHom=0;}
		f01=sum(Het)/Lmut;
		shHet=mean(abs(mutS[Het==1])*mutH[Het==1]);
		if(isNULL(shHet)){shHet=0;}
		sHet=mean(abs(mutS[Het==1]));
		if(isNULL(sHet)){sHet=0;}
		
		relzLoad_f2=Lmut*(f11*sHom+f01*shHet);
		mskLoad_f2=Lmut*f01*((0.5*sHet)-shHet);
		totalLoad_f2=Lmut*(f11*sHom+(0.5*f01)*sHet);
		
		// Calculate the heterozygosity of this individual
		muts0 = indv.haplosomes[0].mutations;
		muts1 = indv.haplosomes[1].mutations;
		// only mutations in chromsome part
		muts0 = muts0[muts0.position<chrEnd];
		muts1 = muts1[muts1.position<chrEnd];
		// Count the shared mutations
		shared_count = sum(match(muts0, muts1) >= 0);
		// All remaining mutations in the genomes are unshared (i.e. heterozygous)
		unshared_count = muts0.size() + muts1.size() - 2 * shared_count;
		// pi is the mean heterozygosity across the chromosome
		pi_ind = unshared_count / chrEnd;
		
		indv_out=sim.cycle +"\t"+ pop.id +"\t"+ index +"\t"+ age +"\t"+ relzLoad_f2 +"\t"+ mskLoad_f2 +"\t"+ totalLoad_f2 +"\t"+ pop.cachedFitness(indv.index) +"\t"+ pi_ind;
		
		out=c(out,indv_out);
	}
	return(out);
}




// Recruitment tracking helpers
// Keeps only simple individual-level reproductive tracking.
// Removed nRecOff because tracking offspring that later recruit is slow.

function (void) initRecruitTrack(o<Individual>$ ind)
{
	if (isNULL(ind.getValue("recruited")))  ind.setValue("recruited", 0);
	if (isNULL(ind.getValue("recruitGen"))) ind.setValue("recruitGen", -1);
	if (isNULL(ind.getValue("nBreed")))     ind.setValue("nBreed", 0);
	if (isNULL(ind.getValue("nOff")))       ind.setValue("nOff", 0);
}

function (void) markRecruited(o<Individual>$ ind)
{
	initRecruitTrack(ind);
	
	if (ind.getValue("recruited") == 0)
	{
		ind.setValue("recruited", 1);
		ind.setValue("recruitGen", sim.cycle);
	}
	
	// Count each breeding event
	ind.setValue("nBreed", ind.getValue("nBreed") + 1);
}

function (void) addOffspringCount(o<Individual>$ ind)
{
	initRecruitTrack(ind);
	ind.setValue("nOff", ind.getValue("nOff") + 1);
}
function (s) mng_rls_load_EFS(o pop, i MINage, i MAXage, i minSize)
{
	cand_parents=pop.individuals[pop.individuals.age>=MINage & pop.individuals.age<=MAXage];
	indvLOAD=getIndvLoadTarget(cand_parents);
	totLOAD=asFloat(sapply(indvLOAD,'strsplit(applyValue,"\t")[6];'));
	rlsLOAD=asFloat(sapply(indvLOAD,'strsplit(applyValue,"\t")[4];'));
	// Directly rank parents
	for(i in 0:(length(rlsLOAD)-1)){
		ind=cand_parents[i];
		ind.setValue("rlsLOAD",rlsLOAD[i]);
	}
	// Assign indv to families
	for(i in cand_parents){
		i.setValue("fam",paste0(i.pedigreeParentIDs[0],"_",i.pedigreeParentIDs[1]));
	}
	UNIQUE=unique(cand_parents.getValue("fam"));
	//	print("families N="+length(UNIQUE));
	// Loop families and retain individuals with less soft load
	sel_parents=c();
	for(fam in UNIQUE){
		fam_indv=cand_parents[which(cand_parents.getValue("fam")==fam)];
		//		print("fam N="+length(fam_indv));
		if(length(fam_indv)>2){
			//			print("rslLOAD="+fam_indv.getValue("rlsLOAD"));
			cutLoad=sort(fam_indv.getValue("rlsLOAD"),ascending=T)[1];
			//			print("cutLoad="+cutLoad);
			fam_indv=fam_indv[fam_indv.getValue("rlsLOAD")<=cutLoad];
			//			print("sel fam N="+length(fam_indv));
		}
		sel_parents=c(sel_parents,fam_indv);
	}
	if (length(sel_parents) >= minSize){
		parents = sample(sel_parents, length(sel_parents));
		BREEDERS=c();
		while(length(parents)>=2){
			indv=sample(parents,1);
			relat=indv.relatedness(parents);
			MINrelat=min(relat);
			if(MINrelat==0){NonRelatRnd=sample(parents[relat==0],1);};
			if(MINrelat<=0.25){NonRelatRnd=sample(parents[relat<=0.25],1);};
			if(MINrelat<0.5){NonRelatRnd=sample(parents[relat<0.5],1);};
			if(MINrelat==0.5){break;};
			parents=setSymmetricDifference(parents,c(indv,NonRelatRnd));
			litterSize = rgamma(1,mu_cond,k_shape);
			//			print(c(paste(indv), paste(NonRelatRnd),paste(litterSize)));
			for (j in 1:litterSize)
			{
				pop.addCrossed(indv, NonRelatRnd);
			}
			BREEDERS_X=sim.cycle+"\t"+indv.pedigreeID+"\t"+paste(indv.pedigreeParentIDs,sep="_")+"\t"+paste(indv.pedigreeGrandparentIDs,sep="_")+"\t"+NonRelatRnd.pedigreeID+"\t"+paste(NonRelatRnd.pedigreeParentIDs,sep="_")+"\t"+paste(NonRelatRnd.pedigreeGrandparentIDs,sep="_")+"\t"+litterSize+"\t"+indv.getValue("rlsLOAD")+"\t"+NonRelatRnd.getValue("rlsLOAD")+"\t"+"NA"+"\t"+"NA";
			BREEDERS=c(BREEDERS,BREEDERS_X);
		}
		return(BREEDERS);
	} else {return(NULL);}
}




